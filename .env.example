# Copy this file to ".env" and fill in your own Groq API key.
# Get a free key at: https://console.groq.com/keys

GROQ_API_KEY=your_groq_api_key_here

# Optional: override the default Groq model
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: OCR embedded images in the PDF.
# Off by default because first-run indexing takes several extra minutes.
# Uses rapidocr-onnxruntime (pure pip, no system Tesseract).
# ENABLE_OCR=1
